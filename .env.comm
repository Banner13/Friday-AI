FRIDAY_VERSION=0.01

# share network setting
SHARED_NETWORK=share-net

# share volumes endpoint
ROOT_DATA=/data/volumes-data
APP_DATA=${ROOT_DATA}/app

# ollama configuration
OLLAMA_NAME=ollama
OLLAMA_PORT=11434
OLLAMA_V_MODELS=${ROOT_DATA}/models/ollama

# openweb-ui 
OWUI_NAME=open-webui
OWUI_PORT=8080
OWUI_HOSTPORT=8080

# docling
DOCLING_NAME=docling
DOCLING_PORT=5001
DOCLING_HOSTPORT=5001

# ! REDIS ！
REDIS_PORT=6379
REDIS_HOSTPORT=6379

# serverless-llm
SLLM_STORE_NAME=sllm-store
SLLM_HEAD_NAME=sllm-head
SLLM_WORKER_NAME=sllm-worker
SLLM_MODEL_FOLDER=/models
SLLM_V_MODELS=${ROOT_DATA}/models/serverless-llm
SLLM_PORT=8343
SLLM_HOST_PORT=8343

# langflow
# https://www.langflow.org/
LFLOW_NAME=langflow
LFLOW_PORT=7860
LFLOW_HOST_PORT=${LFLOW_PORT}
